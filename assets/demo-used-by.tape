# Reverse schema lookup

Output assets/demo-used-by.gif

Set Theme "Catppuccin Mocha"
Set FontSize 16
Set Width 1200
Set Height 520
Set Padding 20
Set TypingSpeed 40ms

Hide
Type "export PATH=/home/hhewett/.local/src/phyllotaxis/target/release:$PATH"
Enter
Type "cd /home/hhewett/.local/src/phyllotaxis/tests/fixtures"
Enter
Type "clear"
Enter
Show

Type "phyll schemas Pet --used-by --spec petstore.yaml"
Enter
Sleep 5s
